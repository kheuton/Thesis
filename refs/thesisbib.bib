  month = jan,
  year = {2025},
  keywords = {Conditional stochastic programming, Contextual optimization, Data-driven optimization, Policy optimization, Task-based learning},
  pages = {271--289},
  file = {ScienceDirect Snapshot:C\:\\Users\\kheut\\Zotero\\storage\\F48MC3XJ\\S0377221724002200.html:text/html;Submitted Version:C\:\\Users\\kheut\\Zotero\\storage\\7FF7H4AY\\Sadana et al. - 2025 - A survey of contextual optimization methods for de.pdf:application/pdf},
}

@article{mandi_decision-focused_2024,
