@techreport{asurv,
  author = {Taylor, L. N. and Ketzler, L. P. and Rousseau D. and Strobel, B. N. and Metzger, K. L. and Butler, M. J.},
  title = {Observations of whooping cranes during winter aerial surveys: 1950–2011.},
  institution = {Aransas National Wildlife Refuge, U.S. Fish and Wildlife Service},
  address = {Austwell, Texas, USA},
  url = {http://dx.doi.org/10.7944/W3RP4B},
  year = {2015},
  abstract = {The Aransas-Wood Buffalo population of whooping cranes (Grus americana) faced a severe decline, nearing extinction by the 1940s. To monitor the population, annual aerial surveys were initiated during the winter of 1950–1951. These surveys aimed to observe and record the number of whooping cranes wintering at the Aransas National Wildlife Refuge (NWR) and surrounding areas. Between the winter of 1950–1951 and the winter of 2010–2011, 38,332 observations of whooping crane groups were marked on paper maps. To preserve and utilize these records, the locations were digitized by matching the screen display in ArcMap 10 as closely as possible to the original paper maps. Approximate points were assigned to each marked location during this process. The resulting digital dataset is archived in a single file:
“WHCR_Aerial_Observations_1950_2011.txt” This file is freely available for download at: http://dx.doi.org/10.7944/W3RP4B.
While this dataset is a valuable resource, users should note the following quality issues and limitations: Inconsistencies in Data Collection: Methods of data collection were not consistently documented. Reliance on Observer Knowledge: Identification of unmarked birds relied heavily on the perceived knowledge of observers. Recording and Digitization Errors: Errors may have been introduced both during the initial recording on paper maps and the subsequent digitization process. These weaknesses should be carefully considered when utilizing the data for research or other purposes.},
}

